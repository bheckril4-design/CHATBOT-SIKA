APP_NAME=SIKA API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEMO_MODE=true
# Version gratuite sans OpenAI: laissez DEMO_MODE=true et OPENAI_API_KEY vide.
ALLOWED_ORIGINS=https://sika.oceanicconseils.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
TRUSTED_HOSTS=sika-api.oceanicconseils.com,sika.oceanicconseils.com,www.sika.oceanicconseils.com,localhost,127.0.0.1,testserver
SERVE_FRONTEND_FROM_BACKEND=false
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=medium
OPENAI_TEXT_VERBOSITY=medium
OPENAI_TEMPERATURE=0.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_KEEP_ALIVE=10m
MAX_HISTORY_MESSAGES=16
RATE_LIMIT_PER_MINUTE=30
# demo | twelve-data | alpha-vantage | exchange-rate-api | auto
MARKET_DATA_PROVIDER=demo
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
EXCHANGE_RATE_API_KEY=
