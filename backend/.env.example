APP_NAME=SIKA API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEMO_MODE=true
ALLOWED_ORIGINS=https://sika.oceanicconseils.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
